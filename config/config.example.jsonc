{
  "version": "1.0.0",
  "system": {
    "trace_enabled": true,
    "log_level": "info",
    "root": "~/.memohub"
  },
  "ai": {
    "providers": [
      { "id": "local", "type": "ollama", "url": "http://localhost:11434/v1" }
    ],
    "agents": {
      "embedder": { "provider": "local", "model": "nomic-embed-text-v2-moe", "dimensions": 768 },
      "summarizer": { "provider": "local", "model": "qwen2.5:7b" }
    }
  },
  "dispatcher": {
    "fallback": "track-insight"
  },
  "tracks": [
    { "id": "track-insight", "name": "Insight Track" },
    { "id": "track-source", "name": "Source Track" },
    { "id": "track-stream", "name": "Stream Track" },
    { "id": "track-wiki", "name": "Wiki Track" }
  ]
}
