{
  "name": "memohub",
  "version": "1.0.0",
  "description": "MemoHub - Agent 智能记忆管理系统 - 多轨道动态矩阵架构",
  "private": true,
  "type": "module",
  "workspaces": ["apps/cli", "packages/*", "tracks/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "eslint 'packages/*/src/**/*.ts' 'tracks/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'tracks/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "clean": "find . -name 'dist' -type d -exec rm -rf {} + 2>/dev/null; true",
    "dev": "bun run --watch apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lancedb/lancedb": "^0.27.2",
    "@types/lru-cache": "^7.10.10",
    "@types/node": "^22.10.0",
    "@types/yaml": "^1.9.7",
    "bun-types": "^1.3.12",
    "eslint": "^9.0.0",
    "log-update": "^8.0.0",
    "lru-cache": "^11.3.5",
    "prettier": "^3.3.0",
    "restore-cursor": "^5.1.0",
    "signal-exit": "^4.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/embaobao/memo-hub.git"
  },
  "author": "zhumeng",
  "license": "MIT",
  "dependencies": {
    "comment-json": "^5.0.0",
    "esprima": "^4.0.1"
  }
}
