{
  "name": "memohub",
  "version": "1.0.0",
  "description": "MemoHub - Agent 智能记忆管理系统 - 多轨道动态矩阵架构",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*", "tracks/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "eslint 'packages/*/src/**/*.ts' 'tracks/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'tracks/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "clean": "find . -name 'dist' -type d -exec rm -rf {} + 2>/dev/null; true",
    "dev": "bun run --watch apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "bun-types": "^1.3.12",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/embaobao/memo-hub.git"
  },
  "author": "zhumeng",
  "license": "MIT"
}
