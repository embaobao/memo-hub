{
  "name": "memory-system-cli",
  "version": "1.0.0",
  "description": "独立的双轨记忆系统 CLI 工具 - GBrain (通用知识) + ClawMem (代码记忆)",
  "main": "dist/cli/index.js",
  "bin": {
    "memory": "dist/cli/index.js",
    "gbrain": "dist/commands/gbrain.js",
    "clawmem": "dist/commands/clawmem.js",
    "memory-search": "dist/commands/search.js",
    "memory-sync": "dist/commands/sync.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "bun run --watch src/cli/index.ts",
    "start": "bun run dist/cli/index.js",
    "test": "bun test",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "memory",
    "vector-database",
    "lancedb",
    "cli",
    "gbrain",
    "clawmem",
    "embedding",
    "semantic-search"
  ],
  "author": "盟哥",
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "chalk": "^5.3.0",
    "inquirer": "^10.0.0",
    "yaml": "^2.6.0",
    "openai": "^6.21.0",
    "zod": "^3.23.8",
    "tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.9.3",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "bun-types": "latest"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/memory-system-cli.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/memory-system-cli/issues"
  },
  "homepage": "https://github.com/your-username/memory-system-cli#readme"
}
